# Supabase — get these from your project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key — never expose this on the client
SUPABASE_SERVICE_KEY=your-service-role-key

# Anthropic Claude API key — for AI reply suggestions in /inbox
ANTHROPIC_API_KEY=sk-ant-...

# Evolution API — WhatsApp messaging gateway (multi-instance rotation)
EVOLUTION_API_URL=https://your-evolution-api.com

# Option A (preferred): JSON array — add/remove instances without code changes
EVOLUTION_INSTANCES_JSON=[{"name":"instance-1","apiKey":"key-1"},{"name":"instance-2","apiKey":"key-2"}]

# Option B (legacy fallback): numbered env vars — gaps are OK, scans up to _20
# EVOLUTION_INSTANCE_1=instance-name-1
# EVOLUTION_API_KEY_1=api-key-1
# EVOLUTION_INSTANCE_2=instance-name-2
# EVOLUTION_API_KEY_2=api-key-2

# Bot server — FastDevBuilds prospect bot on Railway
BOT_SERVER_URL=https://your-bot-server.railway.app
BOT_SERVER_SECRET=your-shared-secret

# PIX key for payment collection
PIX_KEY=your-pix-key
